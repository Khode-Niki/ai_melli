<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<title>رابطه تنگه هرمز با قیمت نفت</title>
<!-- GSAP -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" defer></script>
<!-- Three.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r152/three.min.js" defer></script>
<style>
  /* Reset & Base */
  *{margin:0;padding:0;box-sizing:border-box;}
  html, body{height:100%;font-family:Tahoma,Arial,Helvetica,sans-serif;overflow:hidden;}
  
  /* Three.js canvas */
  #bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:-1;}

  /* Layout */
  .wrapper{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;padding:20px;color:#fff;text-align:center;}
  
  /* Header */
  h1{
    font-size:2.5rem;margin-bottom:1rem;text-shadow:0 2px 8px rgba(0,0,0,.5);
  }
  
  /* Card */
  .card{
    background:rgba(0,0,0,.3);
    backdrop-filter:blur(10px);
    border-radius:12px;
    padding:30px;
    max-width:800px;
    width:100%;
    box-shadow:0 4px 12px rgba(0,0,0,.6);
    opacity:0;
    transform:translateY(40px);
  }
  .card p{font-size:1.1rem;line-height:1.6;}
</style>
</head>
<body>
<canvas id="bg-canvas"></canvas>
<div class="wrapper">
  <h1>رابطه تنگه هرمز با قیمت نفت چیست؟</h1>
  <div class="card" id="card">
    <p>وقتی بازار احتمال دهد عبور نفت از تنگه هرمز با ریسک مواجه می‌شود، چند اتفاق می‌افتد:</p>
    <ul style="text-align:left;text-align: justify;">
      <li>مکانیزم اثر حق بیمه ریسک به قیمت نفت اضافه می‌شود.</li>
      <li>معامله‌گران برای پوشش ریسک، خرید نفت و قراردادهای مرتبط را بیشتر می‌کنند.</li>
      <li>بازار به سمت افزایش نوسان می‌رود.</li>
      <li>حتی اگر فعلاً نفت فیزیکی کم نشود، فقط احتمال اختلال می‌تواند قیمت را بالا ببرد.</li>
    </ul>
    <p>نکته کلیدی در بازار نفت، همیشه خودِ اختلال مهم نیست؛ گاهی فقط ترس از اختلال کافی است.</p>
  </div>
</div>

<script>
  // -------- Three.js Background --------
  const canvas = document.getElementById('bg-canvas');
  const renderer = new THREE.WebGLRenderer({canvas, antialias:true, alpha:true});
  renderer.setSize(window.innerWidth, window.innerHeight);
  
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, window.innerWidth/window.innerHeight, 0.1, 1000);
  camera.position.z = 1;
  
  // Points Cloud
  const geometry = new THREE.BufferGeometry();
  const vertices = [];
  const count = 5000;
  for(let i=0; i<count; i++){
    vertices.push((Math.random()-0.5)*200);
    vertices.push((Math.random()-0.5)*200);
    vertices.push((Math.random()-0.5)*500);
  }
  geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
  const material = new THREE.PointsMaterial({color:0x88e0ff, size:0.8});
  const points = new THREE.Points(geometry, material);
  scene.add(points);
  
  function animate(){
    requestAnimationFrame(animate);
    points.rotation.z += 0.0005;
    renderer.render(scene, camera);
  }
  animate();
  
  window.addEventListener('resize', () => {
    renderer.setSize(window.innerWidth, window.innerHeight);
    camera.aspect = window.innerWidth/window